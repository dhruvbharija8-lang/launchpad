# Copy this file to .env and fill in real values before deploying.

# Secret used to sign admin login tokens — set this to a long random string.
JWT_SECRET=change-this-to-a-long-random-string

# The admin's login (used only the very first time the server starts,
# to create the admin account inside data/db.json). Change the password
# from the dashboard afterwards — editing this file again won't do anything
# once the account already exists.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=ChangeMe123!

# Port the API server listens on.
PORT=4000

# Real student login (Clerk — clerk.com). The publishable key is public/safe
# and lives directly in login.html; the secret key isn't used by any backend
# code yet (this integration is frontend-only for now) — it's just here for
# reference if server-side verification gets added later.
CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
